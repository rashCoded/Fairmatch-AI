# Project Name
PROJECT_NAME="FairMatch AI"

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=fairmatch_ai
POSTGRES_PORT=5432
# Optional: if you prefer a full URL connection string
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/fairmatch

# Security
SECRET_KEY=generate_a_secure_random_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP
OTP_EXPIRE_MINUTES=10

# Email Configuration
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAILS_FROM_EMAIL=your_email@gmail.com
EMAILS_FROM_NAME="FairMatch AI"

# ML Weights (Defaults are 0.50, 0.30, 0.20)
CONTENT_WEIGHT=0.50
COLLABORATIVE_WEIGHT=0.30
AFFIRMATIVE_WEIGHT=0.20
